# PostHog (analytics) — public project API key, EU region.
# Get from PostHog → Settings → Project → API key.
# Add the production value in Vercel project env vars (same name).
NEXT_PUBLIC_POSTHOG_KEY=phc_replace_with_your_project_api_key
# Optional override; defaults to https://eu.posthog.com in code.
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Resend (transactional email) — server-side key, do not prefix with NEXT_PUBLIC_.
RESEND_PORTFOLIO_KEY=re_replace_with_your_resend_api_key
